# GhostCrawler Environment Configuration
# Copy this file to .env and modify as needed

#----------------------------------------------
# ENVIRONMENT SETTINGS
#----------------------------------------------
# Application environment: development, testing, production
NODE_ENV=development
# Enable debug mode (more verbose logging, etc.)
DEBUG=false

#----------------------------------------------
# API SERVER CONFIGURATION
#----------------------------------------------
# Host to bind the API server to (0.0.0.0 for all interfaces)
API_HOST=0.0.0.0
# Port for the API server
API_PORT=8000
# Number of worker processes for the API server
API_WORKERS=4
# Enable auto-reload for development (set to false in production)
API_RELOAD=false
# Comma-separated list of valid API keys for authentication
GHOSTCRAWLER_API_KEYS=your-api-key-here,another-key-here
# Path to JSON file containing API keys (alternative to environment variable)
API_KEYS_FILE=api_keys.json
# URL paths for API documentation
API_DOCS_URL=/docs
API_REDOC_URL=/redoc

#----------------------------------------------
# RATE LIMITING
#----------------------------------------------
# Enable API rate limiting
RATE_LIMIT_ENABLED=true
# Time window for rate limiting in seconds
RATE_LIMIT_WINDOW=60
# Maximum number of requests per window
RATE_LIMIT_MAX_REQUESTS=100
# Default minimum delay between requests to the same domain (seconds)
DEFAULT_MIN_DELAY=1.0
# Default maximum delay between requests to the same domain (seconds)
DEFAULT_MAX_DELAY=60.0
# Enable automatic rate optimization
AUTO_OPTIMIZE_RATES=true

#----------------------------------------------
# DATABASE PATHS
#----------------------------------------------
# Path to the task queue database
QUEUE_DB_PATH=queue.db
# Path to the webhook events database
WEBHOOK_DB_PATH=webhook_events.db
# Path to the rate limiter state database
RATE_LIMITER_DB_PATH=rate_limiter.db
# Path to the main configuration file
CONFIG_FILE_PATH=config.json

#----------------------------------------------
# CRAWLER SETTINGS
#----------------------------------------------
# Maximum number of concurrent browser instances
MAX_BROWSERS=2
# Run browsers in headless mode
HEADLESS=true
# Batch size for URL processing
BATCH_SIZE=10
# Delay between processing URLs in seconds
URL_DELAY=1.0
# Maximum number of retries for failed URLs
MAX_RETRIES=3
# Default output directory for crawled data
OUTPUT_DIR=Specs
# Maximum crawl depth
MAX_DEPTH=3
# Follow external links
FOLLOW_EXTERNAL_LINKS=false
# Respect robots.txt
RESPECT_ROBOTS_TXT=true
# Custom user agent string
USER_AGENT=GhostCrawler/1.0

#----------------------------------------------
# PROXY CONFIGURATION
#----------------------------------------------
# Enable proxy usage
PROXY_ENABLED=false
# Proxy server URL (http://host:port or socks5://host:port)
PROXY_SERVER=
# Proxy username if authentication is required
PROXY_USERNAME=
# Proxy password if authentication is required
PROXY_PASSWORD=
# Proxy rotation policy (round_robin, least_used, random)
PROXY_ROTATION_POLICY=round_robin

#----------------------------------------------
# DATA EXPORTER
#----------------------------------------------
# Output directory for exports
EXPORT_OUTPUT_DIR=exports
# Default export format (json, csv, excel, html)
DEFAULT_EXPORT_FORMAT=json
# Default compression type (none, gzip, zip)
DEFAULT_COMPRESSION=none
# Pretty print JSON output
PRETTY_PRINT=true
# Maximum file size in MB before splitting
MAX_FILE_SIZE_MB=100

#----------------------------------------------
# WEBHOOK NOTIFIER
#----------------------------------------------
# Enable webhook notifications
WEBHOOKS_ENABLED=true
# Maximum concurrent webhook requests
MAX_CONCURRENT_WEBHOOKS=10
# Default number of retries for failed webhook deliveries
DEFAULT_WEBHOOK_RETRY_COUNT=3
# Default delay between retries in seconds
DEFAULT_WEBHOOK_RETRY_DELAY=5.0
# Default timeout for webhook requests in seconds
DEFAULT_WEBHOOK_TIMEOUT=10.0
# Hours after which processed webhook events are purged
PURGE_PROCESSED_AFTER_HOURS=24

#----------------------------------------------
# SYSTEM LIMITS
#----------------------------------------------
# Memory threshold in MB
MEMORY_THRESHOLD_MB=49152
# CPU usage threshold percentage
CPU_THRESHOLD_PERCENT=90
# Disk usage threshold percentage
DISK_THRESHOLD_PERCENT=90
# Maximum total URLs to process
MAX_TOTAL_URLS=1000000
# Maximum concurrent tasks
MAX_CONCURRENT_TASKS=100
# Shutdown timeout in seconds
SHUTDOWN_TIMEOUT=30
# System monitoring interval in seconds
MONITORING_INTERVAL=60

#----------------------------------------------
# LOGGING
#----------------------------------------------
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
# Log file path
LOG_FILE=ghostcrawler.log
# Enable rotation of log files
LOG_ROTATION=true
# Maximum size of log file before rotation (in bytes)
LOG_MAX_SIZE=10485760
# Number of backup log files to keep
LOG_BACKUP_COUNT=5
# Enable logging to console
LOG_TO_CONSOLE=true
# Enable logging to file
LOG_TO_FILE=true
